# ============================================================
# Cerberus — Environment Variables (Template)
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Neo4j Aura connection
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# RocketRide (set by VS Code extension — also add your Anthropic key for pipeline use)
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=your-rocketride-api-key
ROCKETRIDE_ANTHROPIC_KEY=sk-ant-...

# Service URLs (override for local dev without Docker)
NEO4J_MCP_URL=http://127.0.0.1:8787
ROCKETRIDE_URL=http://127.0.0.1:3000

# Cerberus API (for eval script and frontend)
CERBERUS_API=http://localhost:8000
