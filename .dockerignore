# ── Unified .dockerignore ────────────────────────────────────
# Keep the Docker build context small and avoid leaking secrets.
# The unified Dockerfile needs both frontend/ and deploy/.
__pycache__/
*.pyc
*.pyo
.env
.env.*
!.env.example
.git/
.gitignore
tests/
scripts/
seed_data/
pipelines/
neo4j-mcp_Linux_arm64/
docs/
.claude/
docker-compose.yml
# Exclude frontend node_modules (npm ci runs inside Docker)
frontend/node_modules/
frontend/dist/
