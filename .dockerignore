*.pyc
*.pyo
.env
.env.*
!.env.example
.git/
.gitignore
*.md
tests/
scripts/
seed_data/
pipelines/
frontend/
neo4j-mcp_Darwin_arm64/
neo4j-mcp_Linux_arm64/
docs/
deploy/
.claude/
docker-compose.yml
